# Infrastructure Configuration
DB_USER=banking_user
DB_PASSWORD=banking_secure_password
DB_URL=jdbc:postgresql://postgres:5432/accounts

# Kafka / Redpanda Endpoints
# Internal endpoints used by Scala apps inside the docker bridge network
KAFKA_BOOTSTRAP_SERVERS=redpanda:29092

# Storage paths inside application environments
DATA_LAKE_PATH=/opt/banking_data_lake
